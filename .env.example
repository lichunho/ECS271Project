# Optional: override the Hugging Face cache directory (where model weights are stored).
# Default on Windows is %USERPROFILE%\.cache\huggingface\hub
# HF_HOME=D:\hf_cache

# Local LLM (OpenAI-compatible server, e.g. Ollama on :11434, LM Studio on :1234).
# Defaults shown.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=gemma4:latest
